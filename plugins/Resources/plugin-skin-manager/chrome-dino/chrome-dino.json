    "--btn-normal-hover-border-color-light": "#8f8f8f",
    "--btn-normal-active-color-light": "#086bdd",
    "--btn-normal-active-border-color-light": "#086bdd",
    "--btn-primary-bg-light": "#086bdd",
    "--btn-primary-hover-bg-light": "#1976e3",
    "--btn-primary-active-bg-light": "#075fc4",
    "--btn-link-color-light": "#292929",
    "--btn-link-color-dark": "#f1f1f1",
    "--btn-link-hover-color-light": "#086bdd",
