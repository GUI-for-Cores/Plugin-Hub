{
  "schemaVersion": 2,
  "id": "chrome-dino",
  "name": "离线小恐龙",
  "description": "以经典断网页面的纸白、墨黑像素与浏览器蓝为灵感，加入小恐龙、仙人掌、云朵和像素化功能图标。",
  "author": "Codex & Ya",
  "tags": ["像素", "小恐龙", "极简"],
  "ui": {
    "accent": "#086bdd",
    "accentSecondary": "#292929",
    "previewPosition": "center bottom"
  },
  "files": {
    "stylesheet": "chrome-dino.css",
    "background": "chrome-dino-desert.webp",
    "backgroundMime": "image/webp"
  },
  "motion": {
    "clickBursts": true,
    "clickBurstCount": 5,
    "clickBurstSymbols": ["▪", "▫"]
  },
  "variables": {
    "--primary-color": "#086bdd",
    "--secondary-color": "#292929",
    "--color-light": "#292929",
    "--color-dark": "#f1f1f1",
    "--bg-color-light": "#faf9f6",
